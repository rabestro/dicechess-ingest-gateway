# Required: analytics Bearer token (the same INGEST_TOKEN used by observer/sync).
# Held ONLY here, server-side — never shipped to the browser.
INGEST_TOKEN=

# Upstream analytics ingest (POST-only public endpoint).
ANALYTICS_BASE_URL=https://sync.jc.id.lv

# Allowed browser origins — comma-separated. Exact (https://play.jc.id.lv) or
# wildcard subdomain (*.dicechess-play.pages.dev). Defaults cover the play site + Pages previews.
ALLOWED_ORIGINS=https://play.jc.id.lv,https://dicechess-play.pages.dev,*.dicechess-play.pages.dev,http://localhost:5174

# Only relay games from this source; anything else is rejected with 422.
EXPECTED_SOURCE=playsite

# Server port (Koyeb sets PORT automatically).
PORT=8080

# Optional tuning
MAX_BODY_BYTES=262144
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW_MS=60000
